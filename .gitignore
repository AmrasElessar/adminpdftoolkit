# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
.eggs/

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/

# ---------------------------------------------------------------------------
# Testing / type checking / linting caches
# ---------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/

# ---------------------------------------------------------------------------
# Runtime artifacts
# ---------------------------------------------------------------------------
_work/
output/
history.db
history.db-journal
.deps_ok
*.log

# ---------------------------------------------------------------------------
# Build output
# ---------------------------------------------------------------------------
dist/
build/

# ---------------------------------------------------------------------------
# PDF editor assets — fetched by scripts/setup_editor_assets.py at install time
# (kept out of git so the repo stays small; portable build re-fetches them)
# ---------------------------------------------------------------------------
static/pdfjs/
static/fonts/

# ---------------------------------------------------------------------------
# Editor / IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Local environment
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local

# ---------------------------------------------------------------------------
# TLS / secrets
# ---------------------------------------------------------------------------
*.pem
*.key
*.crt
cert/

# ---------------------------------------------------------------------------
# Sample / user PDFs (should not ship in repo)
# ---------------------------------------------------------------------------
*.pdf

# ---------------------------------------------------------------------------
# Benchmark fixtures + saved baselines (scripts/bench_perf.py)
# ---------------------------------------------------------------------------
_bench_samples/
bench_baseline*.json

# ---------------------------------------------------------------------------
# ClamAV — fetched by scripts/setup_clamav.py at install/build time;
# signature databases lazy-downloaded by freshclam on first app boot.
# Whole tree kept out of git so the repo stays small. Operators run the
# setup script on dev / build machines to populate it locally.
# ---------------------------------------------------------------------------
clamav/
_clamav_db_backup/

# ---------------------------------------------------------------------------
# Claude Code / AI assistants
# ---------------------------------------------------------------------------
.claude/

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
zipli
kaspersky.txt
